# ── DeepSeek (pay-per-use, no daily token limits) ─────────────────────────────
# Get an API key at: platform.deepseek.com → API keys → Create
# Warning: every conversation turn makes two LLM calls (intent + response).
# Token usage adds up quickly with long conversations or /eval runs.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Comma-separated list — falls back to next model on rate-limit errors
DEEPSEEK_MODEL=deepseek-chat

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to 1 to print tracebacks on errors
DEBUG=0
